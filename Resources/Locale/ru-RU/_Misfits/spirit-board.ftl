## Spirit Board — séance system locale keys.
## Used by SpiritBoardSystem.cs

# Verb shown to shaman/elder on an inactive board
spirit-board-verb-begin = Начать сеанс

# Verb shown to shaman/elder on an active board (toggle off)
spirit-board-verb-end = Конец сеанса

# Verb shown to ghosts on an active board within range
spirit-board-verb-commune = Общайтесь с живыми

# Cooldown popup sent to activator when board is still cooling down
spirit-board-cooldown = Духам нужно еще { $seconds } секунд, чтобы отдохнуть.

# Atmospheric broadcast to nearby tribe when séance begins
spirit-board-session-started = Руки { $shaman } зависают над доской. Легкий холодок наполняет воздух...

# Atmospheric broadcast when shaman manually ends the session
spirit-board-session-ended-shaman = Шаман поднимает руки. Сеанс окончен.

# Atmospheric broadcast when a ghost chooses GOODBYE
spirit-board-session-ended-goodbye = Планшетка сдвигается с надписью «ДО СВИДАНИЯ». Духи уходят.

# Atmospheric broadcast when the session times out
spirit-board-session-timeout = Доска все еще растет. Духи замолчали.

# Response popup for a single letter (alphabet selection)
spirit-board-response-letter = Холодная рука проводит по букве: { $response }

# Response popup for a multi-character word (YES / NO / MAYBE / GOODBYE)
spirit-board-response-word = Планшетка перемещается к... { $response }

# Ghost-facing BUI window title
spirit-board-window-title = Доска Духов

# Prompt label inside the ghost BUI window
spirit-board-window-prompt = Что говорят духи?

# Label above the alphabet section of the ghost BUI window
spirit-board-window-letters = Назовите букву: