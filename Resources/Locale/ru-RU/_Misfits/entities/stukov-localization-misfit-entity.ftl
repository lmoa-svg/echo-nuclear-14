# #Misfits - чтобы у того, кто это кодил, яйца отсохли
### # Clothing
# # Enclave

ent-N14ClothingUniformJumpsuitEnclaveBlue = синяя униформа Анклава
    .desc = Синяя полевая форма - вариант стандартной униформы Анклава. Ее носит персонал, работающий в более холодных или скрытных условиях.

ent-N14ClothingUniformJumpsuitEnclaveGrey = серая униформа Анклава
    .desc = Серая полевая форма - вариант стандартной униформы анклава. Лучше сочетается с пепельно-серыми руинами и скалистой местностью.

ent-N14ClothingOuterEnclaveCombatArmor = боевая броня Анклава mk.II
    .desc = Улучшенный комплект боевой брони Анклава с усиленным покрытием. Он тяжелее стандартного, но обеспечивает лучшую защиту в полевых условиях.

